# =============================================================================
# HONDANA environment variables.
#   cp .env.example .env   # 値を埋めて使う（.env は git 管理外＝コミットされない）
# ここにはシークレットを置く。モデル/検索などの設定は config.yml 側。
# 値を空にした任意項目は、その機能が無効になるだけで起動には影響しない。
# =============================================================================

# --- LLM プロバイダの API キー（config.yml の provider に応じて必要）---------
ANTHROPIC_API_KEY=your-anthropic-api-key   # provider=claude を使うとき必須
GROQ_API_KEY=                              # provider=groq を使うとき必須（無料枠）
#   ※ LLM をすべてローカル（openai_compat）で動かすなら、上のキーは不要。

# --- 取り込みフォルダ（ホスト側パス。api コンテナにバインドマウントされる）---
HONDANA_INBOX_DIR=/path/to/inbox   # 新規ファイルを置く取り込み元フォルダ
HONDANA_DONE_DIR=/path/to/done     # 取り込み後にファイルを移動する先

# --- API 認証キー（WebUI / MCP 用）------------------------------------------
HONDANA_API_KEY=                   # 空=開放。WebUI の Settings から発行も可。

# --- Qdrant（通常は変更不要。compose 既定で http://qdrant:6333）-------------
# QDRANT_URL=http://qdrant:6333

# --- Hugging Face キャッシュ（ローカル埋め込み使用時のモデル保存先）----------
#   Windows は USERPROFILE が自動設定されるため通常そのままで OK。
#   Linux/Mac で docker compose を使う場合は USERPROFILE を自分のホームに設定:
# USERPROFILE=/home/youruser

# --- 外部公開 URL（WebUI のブックマークレット生成で使用・任意）---------------
#   ブラウザから直接到達できる API の URL。未設定なら http://localhost:8200。
# HONDANA_PUBLIC_URL=http://your-host:8200

# =============================================================================
# 以下はすべて任意機能。使わなければ空のままで OK。
# =============================================================================

# --- Reddit 取り込み（PRAW）-------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=hondana:ingest:1.0

# --- X / Twitter 取り込み（scheduler サービス）------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=

# --- NAS バックアップ（scripts/backup.py）-----------------------------------
#   NAS_HOST が空ならリモート rsync は行わず、ローカルにのみバックアップする。
NAS_HOST=
NAS_USER=
NAS_SSH_KEY_HOST=/path/to/your/ssh_key   # host 側の SSH 秘密鍵パス（docker-compose がマウント）
NAS_BACKUP_ROOT=/volume1/backups/hondana # NAS 側の保存先ディレクトリ
BACKUP_KEEP=10                           # 保持する世代数
